---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/logo.svg" alt="Rugăciuni Sănătate" width="32" height="32" />
          <div class="logo-text">
            <span class="logo-title">Rugăciuni Sănătate</span>
            <span class="logo-sub">hrană pentru suflet</span>
          </div>
        </a>
        <p class="footer-tagline">
          Colecție completă de rugăciuni ortodoxe pentru sănătate, vindecare trupească
          și sufletească, acatiste și psalmi.
        </p>
      </div>
      <div>
        <div class="footer-col-title">Rugăciuni</div>
        <ul class="footer-links">
          <li><a href="/rugaciuni?cat=vindecare">Vindecare</a></li>
          <li><a href="/rugaciuni?cat=dimineata">Dimineață</a></li>
          <li><a href="/rugaciuni?cat=seara">Seară</a></li>
          <li><a href="/rugaciuni?cat=familie">Familie</a></li>
          <li><a href="/rugaciuni?cat=psalmi">Psalmi</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">Sfinți</div>
        <ul class="footer-links">
          <li><a href="/sfinti">Toți sfinții</a></li>
          <li><a href="/sfinti/sfantul-pantelimon">Sf. Pantelimon</a></li>
          <li><a href="/sfinti/sfantul-nectarie">Sf. Nectarie</a></li>
          <li><a href="/sfinti/maica-domnului">Maica Domnului</a></li>
          <li><a href="/calendar">Calendar ortodox</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">Site</div>
        <ul class="footer-links">
          <li><a href="/articole">Articole</a></li>
          <li><a href="/despre">Despre noi</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© {year} Rugăciuni Sănătate. Toate drepturile rezervate.</span>
      <div class="footer-legal">
        <a href="/politica-de-confidentialitate">Confidențialitate</a>
        <a href="/termeni-si-conditii">Termeni</a>
      </div>
    </div>
  </div>
</footer>
