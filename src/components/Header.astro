---
interface Props {
  activeNav?: string;
}
const { activeNav } = Astro.props;

const navLinks = [
  { href: "/", label: "Acasă", key: "acasa" },
  { href: "/rugaciuni", label: "Rugăciuni", key: "rugaciuni" },
  { href: "/sfinti", label: "Sfinți", key: "sfinti" },
  { href: "/articole", label: "Articole", key: "articole" },
  { href: "/calendar", label: "Calendar", key: "calendar" },
];
---

<header>
  <div class="header-inner">
    <a href="/" class="logo">
      <img src="/logo.svg" alt="Rugăciuni Sănătate" class="logo-icon" width="38" height="38" />
      <div class="logo-text">
        <span class="logo-title">Rugăciuni Sănătate</span>
        <span class="logo-sub">hrană pentru suflet</span>
      </div>
    </a>
    <nav aria-label="Navigare principală">
      {navLinks.map((link) => (
        <a href={link.href} class={activeNav === link.key ? "active" : ""}>{link.label}</a>
      ))}
      <a href="/contact" class="header-cta">Contact</a>
    </nav>
    <button
      class="hamburger"
      aria-label="Deschide meniu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      onclick="this.setAttribute('aria-expanded', document.getElementById('mobile-menu').classList.toggle('open')); this.setAttribute('aria-label', document.getElementById('mobile-menu').classList.contains('open') ? 'Închide meniu' : 'Deschide meniu')"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="mobile-menu" id="mobile-menu" aria-label="Meniu mobil">
    {navLinks.map((link) => (
      <a href={link.href} class={activeNav === link.key ? "active" : ""}>{link.label}</a>
    ))}
    <a href="/contact">Contact</a>
  </nav>
</header>
