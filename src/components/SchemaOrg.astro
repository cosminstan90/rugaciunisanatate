---
interface Props {
  schema: object | object[];
}

const { schema } = Astro.props;

const siteOrganization = {
  "@type": "Organization",
  "@id": "https://rugaciunisanatate.ro/#organization",
  name: "Rugăciuni Sănătate",
  alternateName: "Rugaciuni Sanatate",
  url: "https://rugaciunisanatate.ro",
  logo: {
    "@type": "ImageObject",
    "@id": "https://rugaciunisanatate.ro/#logo",
    url: "https://rugaciunisanatate.ro/logo.svg",
    width: 200,
    height: 60,
    caption: "Rugăciuni Sănătate",
  },
  image: { "@id": "https://rugaciunisanatate.ro/#logo" },
  description: "Colecție completă de rugăciuni ortodoxe românești pentru sănătate, vindecare trupească și sufletească, acatiste, psalmi și calendar ortodox zilnic.",
  foundingDate: "2026",
  areaServed: {
    "@type": "Country",
    name: "România",
    identifier: "RO",
  },
  knowsAbout: [
    "rugăciuni ortodoxe",
    "spiritualitate creștină ortodoxă",
    "sfinți tămăduitori",
    "acatiste",
    "psalmi",
    "calendar ortodox",
    "vindecare prin credință",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "contact@rugaciunisanatate.ro",
    availableLanguage: { "@type": "Language", name: "Romanian" },
  },
  sameAs: [
    "https://www.facebook.com/rugaciunisanatate",
    "https://www.instagram.com/rugaciunisanatate",
  ],
};

const webSite = {
  "@type": "WebSite",
  "@id": "https://rugaciunisanatate.ro/#website",
  url: "https://rugaciunisanatate.ro",
  name: "Rugăciuni Sănătate",
  description: "Rugăciuni ortodoxe pentru sănătate, vindecare și familie",
  inLanguage: "ro-RO",
  publisher: { "@id": "https://rugaciunisanatate.ro/#organization" },
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: "https://rugaciunisanatate.ro/rugaciuni?q={search_term_string}",
    },
    "query-input": "required name=search_term_string",
  },
};

const schemas = Array.isArray(schema) ? schema : [schema];

const graph = {
  "@context": "https://schema.org",
  "@graph": [siteOrganization, webSite, ...schemas],
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} />
