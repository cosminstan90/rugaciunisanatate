---
import { getEmDashCollection } from "emdash";
import { ptToText } from "../lib/ptToText";

const today = new Date();
const start = new Date(today.getFullYear(), 0, 0);
const dayOfYear = Math.floor((today.getTime() - start.getTime()) / 86400000);

const { entries: prayers } = await getEmDashCollection("rugaciuni", {
  where: { status: "published" },
  orderBy: { published_at: "asc" },
});

const prayer = prayers.length > 0 ? prayers[dayOfYear % prayers.length] : null;
const slug = prayer?.data.slug ?? prayer?.id;
const title = prayer ? ptToText(prayer.data.title) : "";
const excerpt = prayer ? ptToText(prayer.data.excerpt) : "";
const category = prayer ? ptToText(prayer.data.category) : "";
---

{prayer && (
  <div style="background:var(--parchment-dark);border:1px solid rgba(196,151,58,0.2);border-top:3px solid var(--gold);border-radius:var(--radius);padding:28px 24px;text-align:center">
    <div style="font-family:var(--font-display);font-size:0.7rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);margin-bottom:12px">
      ✦ Rugăciunea zilei ✦
    </div>
    <div style="font-size:1.5rem;margin-bottom:8px">🕯️</div>
    {category && (
      <div style="font-size:0.75rem;color:var(--text-light);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px">{category}</div>
    )}
    <h3 style="font-family:var(--font-display);font-size:1.15rem;font-weight:600;color:var(--dark);margin-bottom:12px;line-height:1.3">
      {title}
    </h3>
    {excerpt && (
      <p style="font-size:0.88rem;line-height:1.7;color:var(--text-light);margin-bottom:16px;font-style:italic">
        {excerpt.length > 120 ? excerpt.slice(0, 120) + "…" : excerpt}
      </p>
    )}
    <a href={`/${slug}?ref=rugaciunea-zilei`} class="btn-primary" style="display:inline-flex">
      Citește rugăciunea →
    </a>
    <div style="margin-top:12px">
      <a href="/rugaciunea-zilei" style="font-size:0.78rem;color:var(--text-light);text-decoration:none">
        Vezi toate rugăciunile zilei →
      </a>
    </div>
  </div>
)}
