---
import {
  getEmDashEntry,
  getEmDashCollection,
  getEntryTerms,
  getSeoMeta,
  decodeSlug,
} from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import ShareButtons from "../components/ShareButtons.astro";
import PrayerCard from "../components/PrayerCard.astro";
import AdSense from "../components/AdSense.astro";
import { ptToText } from "../lib/ptToText";

const rawSlug = Astro.params.slug;
const slug = decodeSlug(rawSlug);

if (!slug) return Astro.redirect("/404");

const { entry: prayer } = await getEmDashEntry("rugaciuni", slug);
if (!prayer) return Astro.redirect("/404");

const siteUrl = "https://rugaciunisanatate.ro";
const pageUrl = `${siteUrl}/${slug}`;

const seo = getSeoMeta(prayer, {
  siteTitle: "Rugăciuni Sănătate",
  siteUrl,
  path: `/${slug}`,
});

const [tags, { entries: relatedPrayers }] = await Promise.all([
  getEntryTerms("rugaciuni", prayer.data.id, "tag"),
  getEmDashCollection("rugaciuni", {
    orderBy: { published_at: "desc" },
    limit: 4,
    where: { status: "published", category: prayer.data.category ?? undefined },
  }),
]);

const related = relatedPrayers.filter((p) => p.id !== prayer.id).slice(0, 3);

const publishedDate = prayer.data.published_at
  ? new Date(prayer.data.published_at).toISOString()
  : undefined;

const faqItems = Array.isArray(prayer.data.faq_items) ? prayer.data.faq_items : [];

const schema = [
  ...(faqItems.length > 0
    ? [
        {
          "@type": "FAQPage",
          "@id": `${pageUrl}#faq`,
          mainEntity: faqItems.map((item: { question: string; answer: string }) => ({
            "@type": "Question",
            name: item.question,
            acceptedAnswer: {
              "@type": "Answer",
              text: item.answer,
            },
          })),
        },
      ]
    : []),
  {
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    headline: ptToText(prayer.data.title),
    description: seo.description,
    url: pageUrl,
    datePublished: publishedDate,
    dateModified: prayer.data.updated_at
      ? new Date(prayer.data.updated_at).toISOString()
      : publishedDate,
    inLanguage: "ro-RO",
    isPartOf: { "@id": "https://rugaciunisanatate.ro/#website" },
    publisher: { "@id": "https://rugaciunisanatate.ro/#organization" },
    ...(prayer.data.bylines?.[0] && {
      author: {
        "@type": "Person",
        name: prayer.data.bylines[0].name,
      },
    }),
    about: {
      "@type": "Thing",
      name: ptToText(prayer.data.category) || "Rugăciune ortodoxă",
    },
    speakable: {
      "@type": "SpeakableSpecification",
      cssSelector: [".prayer-text"],
    },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Acasă", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Rugăciuni", item: `${siteUrl}/rugaciuni` },
      { "@type": "ListItem", position: 3, name: ptToText(prayer.data.title), item: pageUrl },
    ],
  },
];

const author = prayer.data.bylines?.[0];
const initials = author?.name
  ? author.name.split(" ").map((w: string) => w[0]).join("").slice(0, 2).toUpperCase()
  : "RS";
---

<Base
  title={seo.title}
  description={seo.description}
  canonical={pageUrl}
  schema={schema}
  activeNav="rugaciuni"
>
  <Breadcrumb
    crumbs={[
      { label: "Rugăciuni", href: "/rugaciuni" },
      { label: ptToText(prayer.data.title) },
    ]}
  />

  <div class="page-body">
    <main class="prayer-main">
      {ptToText(prayer.data.category) && (
        <div class="prayer-category">✦ {ptToText(prayer.data.category)}</div>
      )}
      <h1 class="prayer-title">{ptToText(prayer.data.title)}</h1>

      {author && (
        <div class="prayer-attribution">
          <div style="font-size:0.82rem;color:var(--text-light)">
            Culegere: <strong style="color:var(--text)">{author.name}</strong>
          </div>
          {prayer.data.reading_time && (
            <div style="font-size:0.82rem;color:var(--text-light);margin-left:auto">
              {prayer.data.reading_time} min citire
            </div>
          )}
        </div>
      )}

      <div class="divider-ornament">
        <span class="divider-ornament-icon">✦</span>
      </div>

      {ptToText(prayer.data.audio_url) && (
        <AudioPlayer src={ptToText(prayer.data.audio_url)} title="Ascultă rugăciunea" />
      )}

      <div class="text-controls">
        <span class="text-ctrl-label">Mărime text:</span>
        <button class="text-ctrl-btn" onclick="changeFontSize(-2)">A−</button>
        <button class="text-ctrl-btn" onclick="changeFontSize(2)">A+</button>
      </div>

      <div class="prayer-text-card">
        <div class="prayer-text" id="prayerText">
          {prayer.data.content
            ? <PortableText value={prayer.data.content} />
            : <p style="color:var(--text-light);font-style:italic">Conținut în curs de adăugare...</p>
          }
        </div>
      </div>

      <ShareButtons url={pageUrl} title={ptToText(prayer.data.title)} />

      <!-- Ad in-article -->
      <div class="in-article-ad">
        <AdSense slot="2345678901" format="horizontal" />
      </div>

      {author && (
        <div class="author-card">
          <div class="author-avatar-circle">
            <span class="author-initials">{initials}</span>
            <div class="author-verified-badge">✓</div>
          </div>
          <div class="author-info">
            <div class="author-eyebrow">✦ Culegere și traducere</div>
            <div class="author-name">{author.name}</div>
            {author.role && <div class="author-role">{author.role}</div>}
            {author.bio && <p class="author-bio-short">{author.bio}</p>}
            <div class="author-row">
              <a href={`/autori/${author.slug}`} class="author-link">Toate rugăciunile →</a>
            </div>
          </div>
        </div>
      )}

      {tags.length > 0 && (
        <div style="margin-top:32px;display:flex;gap:8px;flex-wrap:wrap">
          {tags.map((tag: { slug: string; label: string }) => (
            <a
              href={`/rugaciuni?tag=${tag.slug}`}
              style="font-size:0.8rem;background:var(--parchment-dark);border:1px solid rgba(196,151,58,0.2);border-radius:20px;padding:4px 14px;text-decoration:none;color:var(--text-light)"
            >
              #{tag.label}
            </a>
          ))}
        </div>
      )}

      {related.length > 0 && (
        <div class="related-section">
          <h3 class="related-title">Rugăciuni înrudite</h3>
          <div class="related-grid">
            {related.map((r) => (
              <a href={`/${r.id}`} class="related-card">
                {ptToText(r.data.category) && <div class="related-card-tag">{ptToText(r.data.category)}</div>}
                <div class="related-card-title">{ptToText(r.data.title)}</div>
              </a>
            ))}
          </div>
        </div>
      )}
    </main>

    <!-- SIDEBAR -->
    <aside>
      <div class="sidebar-card">
        <div class="sidebar-card-title">📅 Categorii</div>
        <ul class="sidebar-list">
          {[
            ["vindecare", "Vindecare"],
            ["dimineata", "Dimineață"],
            ["seara", "Seară"],
            ["psalmi", "Psalmi"],
            ["familie", "Familie"],
            ["ocazii", "Ocazii speciale"],
          ].map(([slug, label]) => (
            <li><a href={`/rugaciuni?cat=${slug}`}>{label}</a></li>
          ))}
        </ul>
      </div>

      <div class="sidebar-card">
        <div class="sidebar-card-title">✦ Sfinți tămăduitori</div>
        <ul class="sidebar-list">
          {[
            ["sfantul-pantelimon", "Sf. Pantelimon"],
            ["sfantul-nectarie", "Sf. Nectarie"],
            ["sfantul-luca-al-crimeei", "Sf. Luca al Crimeei"],
            ["sfantul-mina", "Sf. Mina"],
            ["cosma-si-damian", "Sf. Cosma și Damian"],
          ].map(([slug, label]) => (
            <li><a href={`/sfinti/${slug}`}>{label}</a></li>
          ))}
        </ul>
      </div>

      <AdSense slot="3456789012" format="rectangle" class="ad-banner rect" />
    </aside>
  </div>
</Base>

<script>
  function changeFontSize(delta: number) {
    const el = document.getElementById("prayerText");
    if (!el) return;
    const current = parseFloat(getComputedStyle(el).fontSize);
    el.style.fontSize = `${Math.max(12, Math.min(24, current + delta))}px`;
  }
  (window as any).changeFontSize = changeFontSize;
</script>
