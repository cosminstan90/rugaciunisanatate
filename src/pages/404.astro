---
import Base from "../layouts/Base.astro";

Astro.response.status = 404;

const siteUrl = "https://rugaciunisanatate.ro";
---

<Base
  title="Pagina nu a fost găsită — Rugăciuni Sănătate"
  description="Pagina pe care o cauți nu există sau a fost mutată."
  canonical={siteUrl}
  noindex={true}
>
  <div class="not-found">
    <div class="not-found-cross">✝</div>
    <h1>Pagina nu a fost găsită</h1>
    <p>
      Pagina pe care o cauți nu există sau a fost mutată.
      Folosește căutarea sau navighează la colecția noastră de rugăciuni.
    </p>
    <div class="not-found-actions">
      <a href="/" class="btn-primary">Acasă</a>
      <a href="/rugaciuni" class="btn-outline">Toate rugăciunile</a>
    </div>
  </div>
</Base>
