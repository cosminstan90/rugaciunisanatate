---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import AdSense from "../../components/AdSense.astro";

const url = Astro.url;
const page = parseInt(url.searchParams.get("page") ?? "1");
const PER_PAGE = 12;

const { entries: allArticles } = await getEmDashCollection("articole", {
  orderBy: { published_at: "desc" },
  where: { status: "published" },
});

const total = allArticles.length;
const totalPages = Math.ceil(total / PER_PAGE);
const articles = allArticles.slice((page - 1) * PER_PAGE, page * PER_PAGE);

const siteUrl = "https://rugaciunisanatate.ro";
const schema = [
  {
    "@type": "Blog",
    "@id": `${siteUrl}/articole#blog`,
    url: `${siteUrl}/articole`,
    name: "Articole spirituale — Rugăciuni Sănătate",
    description: "Articole despre spiritualitate, sănătate sufletească și viața în credință.",
    inLanguage: "ro-RO",
    publisher: { "@id": `${siteUrl}/#organization` },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Acasă", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Articole", item: `${siteUrl}/articole` },
    ],
  },
];
---

<Base
  title="Articole spirituale — Sănătate sufletească și trupească"
  description="Articole despre rugăciune, sănătate spirituală, viața în credință și vindecarea prin credință."
  canonical={`${siteUrl}/articole`}
  schema={schema}
  activeNav="articole"
>
  <div class="catalog-hero">
    <div class="catalog-hero-inner">
      <div class="catalog-hero-label">✦ Din arhivă ✦</div>
      <h1 class="catalog-hero-title">Articole <em>spirituale</em></h1>
    </div>
  </div>

  <div class="ad-strip">
    <AdSense slot="7890123456" format="horizontal" />
  </div>

  <Breadcrumb crumbs={[{ label: "Articole" }]} />

  <div class="section-inner">
    {articles.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px">
        {articles.map((a) => (
          <ArticleCard
            title={a.data.title}
            slug={a.data.slug ?? a.id}
            excerpt={a.data.excerpt}
            category={a.data.category}
            readingTime={a.data.reading_time}
            publishedAt={a.data.published_at}
          />
        ))}
      </div>
    ) : (
      <div style="text-align:center;padding:80px 20px;color:var(--text-light)">
        <div style="font-size:3rem;margin-bottom:16px">📖</div>
        <p>Articolele sunt în curs de publicare.</p>
      </div>
    )}

    {totalPages > 1 && (
      <nav class="pagination" aria-label="Paginare">
        {page > 1 && <a href={`?page=${page - 1}`}>‹</a>}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
          p === page ? <span>{p}</span> : <a href={`?page=${p}`}>{p}</a>
        ))}
        {page < totalPages && <a href={`?page=${page + 1}`}>›</a>}
      </nav>
    )}
  </div>
</Base>
