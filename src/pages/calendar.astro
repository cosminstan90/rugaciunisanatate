---
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import AdSense from "../components/AdSense.astro";
import { calendarOrtodox, getZiCalendar } from "../data/calendar-ortodox";
import { getEmDashCollection } from "emdash";
import { ptToText } from "../lib/ptToText";

const url = Astro.url;
const today = new Date();

// Parse ?luna=YYYY-MM from query, default to current month
const lunaParam = url.searchParams.get("luna");
let viewDate: Date;
if (lunaParam && /^\d{4}-\d{2}$/.test(lunaParam)) {
  viewDate = new Date(`${lunaParam}-01`);
} else {
  viewDate = new Date(today.getFullYear(), today.getMonth(), 1);
}

const year = viewDate.getFullYear();
const month = viewDate.getMonth(); // 0-based

const LUNI_RO = [
  "Ianuarie", "Februarie", "Martie", "Aprilie", "Mai", "Iunie",
  "Iulie", "August", "Septembrie", "Octombrie", "Noiembrie", "Decembrie",
];
const ZILE_RO = ["Lu", "Ma", "Mi", "Jo", "Vi", "Sâ", "Du"];

// Build calendar grid
const firstDay = new Date(year, month, 1);
const lastDay = new Date(year, month + 1, 0);
const startOffset = (firstDay.getDay() + 6) % 7; // Monday = 0
const totalCells = Math.ceil((startOffset + lastDay.getDate()) / 7) * 7;

const cells: Array<{ day: number | null; date?: Date }> = [];
for (let i = 0; i < totalCells; i++) {
  const dayNum = i - startOffset + 1;
  if (dayNum < 1 || dayNum > lastDay.getDate()) {
    cells.push({ day: null });
  } else {
    cells.push({ day: dayNum, date: new Date(year, month, dayNum) });
  }
}

// Prev/next month navigation
const prevDate = new Date(year, month - 1, 1);
const nextDate = new Date(year, month + 1, 1);
const prevParam = `${prevDate.getFullYear()}-${String(prevDate.getMonth() + 1).padStart(2, "0")}`;
const nextParam = `${nextDate.getFullYear()}-${String(nextDate.getMonth() + 1).padStart(2, "0")}`;

// Today's saint info
const todayZi = getZiCalendar(today);
const siteUrl = "https://rugaciunisanatate.ro";

// Fetch saints from DB and build feast date → slug map
const { entries: sfinti } = await getEmDashCollection("sfinti", {
  where: { status: "published" },
}).catch(() => ({ entries: [] as any[] }));

const LUNI_MAP: Record<string, string> = {
  "ianuarie": "01", "februarie": "02", "martie": "03",
  "aprilie": "04", "mai": "05", "iunie": "06",
  "iulie": "07", "august": "08", "septembrie": "09",
  "octombrie": "10", "noiembrie": "11", "decembrie": "12",
};

function parseFeastDate(feastDate: string): string | null {
  const match = feastDate.toLowerCase().match(/(\d{1,2})\s+(\w+)/);
  if (!match || !match[1] || !match[2]) return null;
  const day = match[1].padStart(2, "0");
  const month = LUNI_MAP[match[2]];
  if (!month) return null;
  return `${month}-${day}`;
}

// Map "MM-DD" → { slug, name }
const saintByDate: Record<string, { slug: string; name: string }> = {};
for (const s of sfinti) {
  const feastRaw = ptToText(s.data.feast_date);
  if (!feastRaw) continue;
  const key = parseFeastDate(feastRaw);
  if (key) {
    saintByDate[key] = {
      slug: s.data.slug ?? s.id,
      name: ptToText(s.data.name),
    };
  }
}

// Today's saint page link
const todayMm = String(today.getMonth() + 1).padStart(2, "0");
const todayDd = String(today.getDate()).padStart(2, "0");
const todaySaintPage = saintByDate[`${todayMm}-${todayDd}`];

const schema = [
  {
    "@type": "WebPage",
    "@id": `${siteUrl}/calendar#page`,
    url: `${siteUrl}/calendar`,
    name: "Calendar Ortodox — Rugăciuni Sănătate",
    description: "Calendarul ortodox complet cu sfinții fiecărei zile, zile de post și dezlegări.",
    inLanguage: "ro-RO",
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Acasă", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Calendar Ortodox", item: `${siteUrl}/calendar` },
    ],
  },
];
---

<Base
  title={`Calendar Ortodox ${LUNI_RO[month]} ${year} — Rugăciuni Sănătate`}
  description={`Calendarul ortodox pentru ${LUNI_RO[month]} ${year}. Sfinții fiecărei zile, zile de post și dezlegări.`}
  canonical={`${siteUrl}/calendar`}
  schema={schema}
  activeNav="calendar"
>
  <div class="calendar-hero" style="background:var(--dark);padding:48px 32px;text-align:center">
    <div class="section-label">✦ Calendar Creștin Ortodox ✦</div>
    <h1 class="section-title" style="color:var(--white);margin-top:8px">
      Calendar <em style="color:var(--gold)">Ortodox</em>
    </h1>
  </div>

  <Breadcrumb crumbs={[{ label: "Calendar Ortodox" }]} />

  <div class="calendar-grid-wrap">
    <!-- CALENDAR PRINCIPAL -->
    <div>
      <div class="calendar-month">
        <div class="calendar-month-header">
          <a href={`/calendar?luna=${prevParam}`} class="calendar-nav-btn" aria-label="Luna anterioară">‹</a>
          <div class="calendar-month-title">{LUNI_RO[month]} {year}</div>
          <a href={`/calendar?luna=${nextParam}`} class="calendar-nav-btn" aria-label="Luna următoare">›</a>
        </div>

        <div class="calendar-weekdays">
          {ZILE_RO.map((z) => <div class="calendar-weekday">{z}</div>)}
        </div>

        <div class="calendar-days">
          {cells.map(({ day, date }) => {
            if (!day || !date) {
              return <div style="background:rgba(0,0,0,0.02);border-right:1px solid rgba(196,151,58,0.08);border-bottom:1px solid rgba(196,151,58,0.08);min-height:72px"></div>;
            }
            const mm = String(month + 1).padStart(2, "0");
            const dd = String(day).padStart(2, "0");
            const zi = calendarOrtodox[`${mm}-${dd}`];
            const isToday = date.toDateString() === today.toDateString();
            const isSunday = date.getDay() === 0;
            return (
              <div
                class:list={["calendar-day", isToday && "today", zi?.tip === "mare" && "feast"]}
                style={isSunday ? "color:var(--crimson)" : ""}
                title={zi?.sfinti[0] ?? ""}
              >
                <div class="day-num" style={isSunday ? "color:var(--crimson)" : ""}>{day}</div>
                {zi && (
                  <div class="day-saint">
                    {zi.post && <span class="day-post" title="Post"></span>}
                    {(() => {
                      const mmStr = String(month + 1).padStart(2, "0");
                      const ddStr = String(day).padStart(2, "0");
                      const saintPage = saintByDate[`${mmStr}-${ddStr}`];
                      return saintPage
                        ? <a href={`/sfinti/${saintPage.slug}`} style="color:inherit;text-decoration:none;border-bottom:1px dotted rgba(196,151,58,0.4)" title={`Pagina ${saintPage.name}`}>{zi.sfinti[0]}</a>
                        : zi.sfinti[0];
                    })()}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>

      <!-- Legend -->
      <div style="display:flex;gap:20px;margin-top:16px;flex-wrap:wrap;font-size:0.78rem;color:var(--text-light)">
        <div style="display:flex;align-items:center;gap:6px">
          <div style="width:16px;height:3px;background:var(--gold);border-radius:2px"></div>
          Sărbătoare mare
        </div>
        <div style="display:flex;align-items:center;gap:6px">
          <span class="day-post" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--crimson)"></span>
          Zi de post
        </div>
        <div style="display:flex;align-items:center;gap:6px">
          <div style="width:16px;height:16px;background:rgba(139,26,42,0.06);border-radius:2px"></div>
          Ziua de azi
        </div>
      </div>
    </div>

    <!-- SIDEBAR: Sfântul de azi -->
    <div style="display:flex;flex-direction:column;gap:20px">
      <div class="today-saint-panel">
        <span class="saint-icon">{todayZi?.icona ?? "✝️"}</span>
        <div class="today-label">✦ Astăzi, {today.toLocaleDateString("ro-RO", { weekday: "long", day: "numeric", month: "long" })}</div>
        <div class="today-name">{todayZi?.sfinti[0] ?? "Zi obișnuită"}</div>
        {todayZi?.sfinti && todayZi.sfinti.length > 1 && (
          <p class="today-desc">
            Și: {todayZi.sfinti.slice(1).join(" · ")}
          </p>
        )}
        {todayZi?.post && (
          <div style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;background:rgba(139,26,42,0.08);border:1px solid rgba(139,26,42,0.2);color:var(--crimson);border-radius:20px;padding:5px 14px;margin-bottom:12px">
            🍃 Zi de post
          </div>
        )}
        {todayZi?.dezlegare && (
          <div style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;background:rgba(196,151,58,0.08);border:1px solid rgba(196,151,58,0.25);color:var(--gold);border-radius:20px;padding:5px 14px;margin-bottom:12px;margin-left:8px">
            ✦ Dezlegare la {todayZi.dezlegare}
          </div>
        )}
        {todaySaintPage ? (
          <a href={`/sfinti/${todaySaintPage.slug}`} class="btn-primary" style="display:inline-flex;width:100%;justify-content:center;margin-top:8px">
            Rugăciunile {todaySaintPage.name.replace("Sfântul ", "Sf. ").replace("Sfânta ", "Sf. ")} →
          </a>
        ) : (
          <a href="/rugaciuni/vindecare" class="btn-primary" style="display:inline-flex;width:100%;justify-content:center;margin-top:8px">
            Rugăciunile zilei →
          </a>
        )}
      </div>

      <AdSense slot="0123456789" format="rectangle" class="ad-banner rect" />

      <!-- Posturi în an -->
      <div class="sidebar-card">
        <div class="sidebar-card-title">📅 Posturi principale</div>
        <ul class="sidebar-list">
          <li><a href="/rugaciuni?cat=post">Postul Paștelui (Mare)</a></li>
          <li><a href="/rugaciuni?cat=post">Postul Crăciunului</a></li>
          <li><a href="/rugaciuni?cat=post">Postul Sf. Ap. Petru și Pavel</a></li>
          <li><a href="/rugaciuni?cat=post">Postul Sf. Fecioare Maria</a></li>
          <li><a href="/rugaciuni?cat=post">Post în fiecare miercuri și vineri</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Sărbători luna curentă -->
  <div class="section-inner" style="padding-top:0">
    <div class="section-label" style="margin-bottom:16px">✦ Sărbători mari în {LUNI_RO[month]}</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px">
      {cells
        .filter(({ day, date }) => {
          if (!day || !date) return false;
          const mm = String(month + 1).padStart(2, "0");
          const dd = String(day).padStart(2, "0");
          const zi = calendarOrtodox[`${mm}-${dd}`];
          return zi?.tip === "mare";
        })
        .map(({ day, date }) => {
          const mm = String(month + 1).padStart(2, "0");
          const dd = String(day).padStart(2, "0");
          const zi = calendarOrtodox[`${mm}-${dd}`]!;
          return (
            <div style="background:var(--white);border:1px solid rgba(196,151,58,0.2);border-top:2px solid var(--gold);border-radius:var(--radius);padding:16px">
              <div style="font-family:var(--font-display);font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold);margin-bottom:6px">
                {dd} {LUNI_RO[month]}
              </div>
              <div style="font-size:1.2rem;margin-bottom:8px">{zi.icona ?? "✝️"}</div>
              <div style="font-family:var(--font-display);font-size:0.95rem;font-weight:600;color:var(--dark)">
                {zi.sfinti[0]}
              </div>
              {zi.dezlegare && (
                <div style="margin-top:8px;font-size:0.75rem;color:var(--gold)">
                  Dezlegare la {zi.dezlegare}
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</Base>
