---
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const siteUrl = "https://rugaciunisanatate.ro";
const schema = [
  {
    "@type": "AboutPage",
    "@id": `${siteUrl}/despre#page`,
    url: `${siteUrl}/despre`,
    name: "Despre noi — Rugăciuni Sănătate",
    inLanguage: "ro-RO",
    isPartOf: { "@id": `${siteUrl}/#website` },
    about: { "@id": `${siteUrl}/#organization` },
    description: "Rugăciuni Sănătate este o redacție editorială specializată în spiritualitate ortodoxă, dedicată publicării de rugăciuni autentice, vieți ale sfinților și articole despre credință și sănătate.",
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Acasă", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Despre noi", item: `${siteUrl}/despre` },
    ],
  },
];
---

<Base
  title="Despre noi — Rugăciuni Sănătate"
  description="Rugăciuni Sănătate este o resursă editorială ortodoxă românească dedicată rugăciunilor autentice pentru sănătate, vindecare și viață duhovnicească."
  canonical={`${siteUrl}/despre`}
  schema={schema}
>
  <Breadcrumb crumbs={[{ label: "Despre noi" }]} />

  <div class="static-page">
    <div class="ornament" style="margin-bottom:24px">Despre noi</div>
    <h1>Hrană pentru suflet</h1>

    <p>
      <strong>Rugăciunisanatate.ro</strong> este o resursă editorială ortodoxă românească,
      dedicată publicării de rugăciuni autentice, acatiste, psalmi și informații despre
      sfinții tămăduitori ai Bisericii Ortodoxe.
    </p>

    <p>
      Credem că rugăciunea vindecă — nu numai sufletul, ci și trupul. Tradiția bimilenară
      a Bisericii, confirmată tot mai mult de cercetarea medicală modernă, arată că
      rugăciunea aduce pace, reduce stresul și întărește sistemul imunitar.
    </p>

    <h2>Misiunea noastră</h2>
    <p>
      Ne-am propus să punem la îndemâna tuturor românilor cea mai completă colecție de
      rugăciuni ortodoxe pentru sănătate — rugăciuni de vindecare, acatiste, psalmi,
      rugăciuni de dimineață și de seară, rugăciuni pentru cei dragi.
    </p>
    <p>
      Fiecare rugăciune publicată pe acest site provine din surse tradiționale ortodoxe
      (Ceaslov, Molitfelnic, Psaltire) sau din tradiția vie a Bisericii. Textele sunt
      verificate cu atenție și prezentate într-o română accesibilă tuturor.
    </p>

    <h2>Standarde editoriale</h2>
    <p>
      Redacția noastră respectă următoarele principii:
    </p>
    <ul style="line-height:2;color:var(--text)">
      <li><strong>Autenticitate</strong> — publicăm exclusiv rugăciuni din tradiția ortodoxă autentică</li>
      <li><strong>Acuratețe</strong> — textele sunt verificate față de sursele liturgice originale</li>
      <li><strong>Accesibilitate</strong> — prezentăm conținutul spiritual într-un limbaj clar și modern</li>
      <li><strong>Responsabilitate</strong> — rugăciunile nu înlocuiesc consultul medical; credem în complementaritatea credinței și medicinei</li>
    </ul>

    <h2>Calendarul Ortodox</h2>
    <p>
      Secțiunea de <a href="/calendar">Calendar Ortodox</a> afișează zilnic sfinții prăznuiți,
      zilele de post și dezlegările — o busolă spirituală pentru viața de zi cu zi în credință.
      Calendarul acoperă toate cele 365 de zile ale anului bisericesc ortodox.
    </p>

    <h2>Sfinții tămăduitori</h2>
    <p>
      Un capitol important al site-ului este dedicat <a href="/sfinti">sfinților cu darul vindecării</a>:
      Sfântul Pantelimon, Sfântul Nectarie de la Eghina, Sfântul Luca al Crimeei,
      Sfinții Cosma și Damian, Sfânta Parascheva și mulți alții. Fiecare sfânt are propria
      pagină cu rugăciuni, context istoric și viața descrisă pe scurt.
    </p>

    <h2>Contact și colaborare</h2>
    <p>
      Suntem deschiși colaborărilor cu preoți, teologi și autori cu formare ortodoxă care
      doresc să contribuie cu rugăciuni, articole sau corectări de conținut.
    </p>
    <p>
      Ne puteți contacta la <a href="mailto:contact@rugaciunisanatate.ro">contact@rugaciunisanatate.ro</a>
      sau prin <a href="/contact">pagina de contact</a>.
    </p>

    <div style="margin-top:40px;padding:24px;background:var(--parchment-dark);border:1px solid rgba(196,151,58,0.2);border-radius:var(--radius)">
      <div class="ornament" style="margin-bottom:16px">✦</div>
      <p style="text-align:center;font-family:var(--font-display);font-size:1.1rem;font-style:italic;color:var(--dark)">
        „Rugați-vă neîncetat." — 1 Tesaloniceni 5:17
      </p>
    </div>

    <div style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap">
      <a href="/rugaciuni" class="btn-primary">Explorează rugăciunile</a>
      <a href="/contact" class="btn-outline">Contactează-ne</a>
    </div>
  </div>
</Base>
