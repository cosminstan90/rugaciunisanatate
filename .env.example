# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/rugaciunisanatate

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA4_ID=

# Google Search Console verification code (content attr value)
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification code (content attr value)
PUBLIC_BING_VERIFICATION=

# Google AdSense Publisher ID (e.g. ca-pub-XXXXXXXXXXXXXXXX)
# Configurable also from EmDash admin → Site Settings → Custom Fields
PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
