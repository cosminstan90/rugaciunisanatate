# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/rugaciunisanatate

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA4_ID=G-2W142YYJQ8

# Google Search Console verification code (content attr value)
